<!-- package-tools/pages/decoration/decoration.wxml -->
<view class="page-wrapper"><view class="container"><view class="section"><view class="section-title">🎨 装修预算计算器</view>
<view class="form-group"><text class="form-label">房屋面积（㎡）</text><input class="form-input" type="digit" placeholder="输入面积" value="{{area}}" bindinput="onInput"/></view>
<view class="form-group"><text class="form-label">装修档次</text><view class="option-group">
<view class="option-item {{level==='simple'?'active':''}}" bindtap="setLevel" data-v="simple">简装 800-1200元/㎡</view>
<view class="option-item {{level==='mid'?'active':''}}" bindtap="setLevel" data-v="mid">中装 1500-2500元/㎡</view>
<view class="option-item {{level==='luxury'?'active':''}}" bindtap="setLevel" data-v="luxury">精装 3000-5000元/㎡</view>
</view></view>
<view class="result-card" wx:if="{{total}}"><text class="result-label">预估装修总价</text><text class="result-value">{{total}} 万元</text></view>
</view></view></view>
