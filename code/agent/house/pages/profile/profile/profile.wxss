/* pages/profile/profile/profile.wxss */

.profile-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 60rpx 40rpx 40rpx;
  display: flex; align-items: center; gap: 24rpx;
}
.avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center; font-size: 56rpx;
  flex-shrink: 0;
}
.avatar-placeholder {
  font-size: 22rpx; color: rgba(255,255,255,0.9); text-align: center;
}
.avatar-img {
  width: 120rpx; height: 120rpx; border-radius: 50%; flex-shrink: 0;
  border: 3rpx solid rgba(255,255,255,0.5);
}
.user-info { display: flex; flex-direction: column; gap: 8rpx; flex: 1; min-width: 0; }
.user-name { font-size: 36rpx; font-weight: 700; color: #ffffff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.user-desc { font-size: 24rpx; color: rgba(255,255,255,0.8); }
.login-btn {
  background: rgba(255,255,255,0.25); border-radius: 40rpx;
  padding: 12rpx 32rpx; flex-shrink: 0;
}
.login-btn:active { opacity: 0.7; }
.login-text { font-size: 26rpx; color: #fff; }

.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; }
.stat-card {
  display: flex; flex-direction: column; align-items: center; padding: 24rpx 12rpx;
  background: var(--bg-gray); border-radius: var(--radius-md);
}
.stat-card:active { opacity: 0.7; }
.stat-num { font-size: 40rpx; font-weight: 700; color: var(--primary-color); }
.stat-label { font-size: 22rpx; color: var(--text-light); margin-top: 4rpx; }

.menu-section { padding: 0; }
.menu-item {
  display: flex; align-items: center; padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: var(--bg-light-gray); }
.menu-item.danger .menu-text { color: var(--error-color); }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-text { flex: 1; font-size: 30rpx; color: var(--text-primary); }
.menu-arrow { font-size: 28rpx; color: var(--text-light); }

.about-section { margin-top: 24rpx; }
.about-info { display: flex; flex-direction: column; align-items: center; padding: 24rpx; }
.about-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 12rpx; }
.about-desc { font-size: 22rpx; color: var(--text-light); text-align: center; line-height: 1.6; white-space: pre-wrap; }

/* 购房需求摘要 */
.demand-section {
  margin: 24rpx 24rpx 0;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.demand-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.demand-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.demand-edit {
  font-size: 24rpx;
  color: var(--primary-color);
}
.demand-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}
.demand-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 12rpx;
  background: var(--bg-gray);
  border-radius: 12rpx;
}
.demand-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
}
.demand-label {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}
.demand-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}
.demand-tag {
  font-size: 22rpx;
  color: var(--primary-color);
  background: rgba(24, 144, 255, 0.08);
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
}

/* 无数据引导 */
.demand-empty {
  margin: 24rpx 24rpx 0;
  padding: 32rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.empty-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
}
.empty-btn {
  padding: 12rpx 48rpx;
  background: var(--primary-color);
  border-radius: 32rpx;
}
.empty-btn:active { opacity: 0.85; }
.empty-btn-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

/* 编辑图标 */
.edit-icon {
  flex-shrink: 0;
  padding: 12rpx 16rpx;
  font-size: 36rpx;
}
