/* pages/profile/edit/edit.wxss - 用户信息编辑 */

.edit-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 24rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
}
.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}
.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
}
.avatar-default {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
}
.avatar-default-icon {
  font-size: 64rpx;
}
.avatar-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}
.avatar-badge-text {
  font-size: 24rpx;
}
.avatar-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
  padding: 28rpx 32rpx 12rpx;
  background: #f5f5f5;
}
.section-hint {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--text-light, #999);
}

.form-group {
  background: #ffffff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}
.form-item:last-child { border-bottom: none; }

.form-label {
  font-size: 28rpx;
  color: var(--text-primary, #333);
  width: 160rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary, #333);
  text-align: right;
  height: 48rpx;
  line-height: 48rpx;
}
.form-input-placeholder { color: #c0c0c0; }

.form-unit {
  font-size: 24rpx;
  color: var(--text-light, #999);
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* 预算行 */
.budget-row {
  display: flex;
  align-items: center;
  flex: 1;
}
.budget-input {
  flex: 1;
  min-width: 0;
}
.budget-sep {
  font-size: 28rpx;
  color: var(--text-light, #999);
  padding: 0 12rpx;
  flex-shrink: 0;
}
.budget-unit {
  font-size: 24rpx;
  color: var(--text-light, #999);
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* 选择器 */
.picker-item picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
.picker-text {
  font-size: 28rpx;
  color: var(--text-primary, #333);
}
.picker-arrow {
  font-size: 28rpx;
  color: var(--text-light, #999);
  margin-left: 12rpx;
}

/* 优先级标签 */
.priority-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx 32rpx 24rpx;
  margin: 0 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.priority-tag {
  padding: 14rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text-secondary, #666);
  background: #f5f5f5;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.priority-tag.active {
  color: #1890ff;
  background: rgba(24, 144, 255, 0.08);
  border-color: #1890ff;
}

/* 保存按钮 */
.save-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
}
.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: 44rpx;
  text-align: center;
}
.save-btn::after { border: none; }
.save-btn.disabled {
  opacity: 0.6;
}
.save-btn:active { opacity: 0.85; }
