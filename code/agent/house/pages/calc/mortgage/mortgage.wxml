<!-- pages/calc/mortgage/mortgage.wxml - 房贷计算器 -->
<view class="page-wrapper">
  <!-- 还款方式切换 -->
  <view class="method-tabs">
    <view class="method-tab {{method === 'equal_payment' ? 'active' : ''}}" bindtap="switchMethod" data-method="equal_payment">
      等额本息
    </view>
    <view class="method-tab {{method === 'equal_principal' ? 'active' : ''}}" bindtap="switchMethod" data-method="equal_principal">
      等额本金
    </view>
    <view class="method-tab {{method === 'combined' ? 'active' : ''}}" bindtap="switchMethod" data-method="combined">
      组合贷款
    </view>
  </view>

  <view class="container">
    <!-- 贷款信息 -->
    <view class="section">
      <view class="section-title">📋 贷款信息</view>

      <!-- 房屋总价 -->
      <view class="form-group">
        <text class="form-label">房屋总价（万元）</text>
        <input class="form-input" type="digit" placeholder="请输入房屋总价" value="{{totalPrice}}" bindinput="onInput" data-field="totalPrice" />
      </view>

      <!-- 首付比例 -->
      <view class="form-group">
        <text class="form-label">首付比例：{{downPaymentRatio}}%</text>
        <slider min="20" max="90" value="{{downPaymentRatio}}" step="5" activeColor="#1890ff" bindchange="onRatioChange" data-field="downPaymentRatio" show-value="{{false}}" />
        <view class="ratio-marks">
          <text bindtap="setRatio" data-value="20">20%</text>
          <text bindtap="setRatio" data-value="30">30%</text>
          <text bindtap="setRatio" data-value="40">40%</text>
          <text bindtap="setRatio" data-value="50">50%</text>
          <text bindtap="setRatio" data-value="60">60%</text>
          <text bindtap="setRatio" data-value="70">70%</text>
        </view>
      </view>

      <!-- 首付/贷款额 -->
      <view class="down-payment-info">
        <view class="dp-item">
          <text class="dp-label">首付金额</text>
          <text class="dp-value">{{downPayment}}万元</text>
        </view>
        <view class="dp-item">
          <text class="dp-label">贷款金额</text>
          <text class="dp-value primary">{{loanAmount}}万元</text>
        </view>
      </view>

      <!-- 贷款期限 -->
      <view class="form-group">
        <text class="form-label">贷款期限</text>
        <view class="term-options">
          <view class="term-option {{loanTerm === item ? 'active' : ''}}" wx:for="{{termOptions}}" wx:key="index" bindtap="setTerm" data-value="{{item}}">
            {{item}}年
          </view>
        </view>
      </view>

      <!-- 贷款利率 -->
      <view class="form-group">
        <text class="form-label">年利率（%）</text>
        <view class="rate-presets">
          <view class="rate-preset" bindtap="setRate" data-value="3.1">公积金 3.1%</view>
          <view class="rate-preset" bindtap="setRate" data-value="3.5">商贷 3.5%</view>
          <view class="rate-preset" bindtap="setRate" data-value="4.0">商贷 4.0%</view>
          <view class="rate-preset" bindtap="setRate" data-value="4.5">商贷 4.5%</view>
        </view>
        <input class="form-input" type="digit" placeholder="输入年利率" value="{{rate}}" bindinput="onInput" data-field="rate" />
      </view>
    </view>

    <!-- 组合贷信息（仅组合贷模式显示） -->
    <view class="section" wx:if="{{method === 'combined'}}">
      <view class="section-title">🏦 组合贷款</view>

      <view class="form-group">
        <text class="form-label">公积金贷款金额（万元）</text>
        <input class="form-input" type="digit" placeholder="公积金额度" value="{{fundAmount}}" bindinput="onInput" data-field="fundAmount" />
      </view>

      <view class="form-group">
        <text class="form-label">公积金利率（%）</text>
        <input class="form-input" type="digit" placeholder="如 3.1" value="{{fundRate}}" bindinput="onInput" data-field="fundRate" />
      </view>

      <view class="form-group">
        <text class="form-label">商业贷款利率（%）</text>
        <input class="form-input" type="digit" placeholder="如 3.5" value="{{commercialRate}}" bindinput="onInput" data-field="commercialRate" />
      </view>

      <view class="down-payment-info">
        <view class="dp-item">
          <text class="dp-label">商业贷款</text>
          <text class="dp-value">{{commercialAmount}}万元</text>
        </view>
        <view class="dp-item">
          <text class="dp-label">公积金贷款</text>
          <text class="dp-value primary">{{fundAmount}}万元</text>
        </view>
      </view>
    </view>

    <!-- 计算按钮 -->
    <button class="btn-primary calc-btn" bindtap="calculate">开始计算</button>

    <!-- 计算结果 -->
    <view class="section result-section" wx:if="{{result}}">
      <view class="section-title">📊 计算结果</view>

      <!-- 核心数据卡片 -->
      <view class="result-cards">
        <view class="result-card">
          <text class="result-card-value {{method === 'equal_principal' ? '' : 'price'}}">{{result.monthlyPayment || '--'}}</text>
          <text class="result-card-unit">{{method === 'equal_principal' ? '首月月供(元)' : '每月月供(元)'}}</text>
        </view>
        <view class="result-card">
          <text class="result-card-value">{{result.totalPaymentStr || '--'}}</text>
          <text class="result-card-unit">还款总额(万)</text>
        </view>
        <view class="result-card">
          <text class="result-card-value price">{{result.totalInterestStr || '--'}}</text>
          <text class="result-card-unit">利息总额(万)</text>
        </view>
      </view>

      <!-- 等额本金特有 -->
      <view class="extra-info" wx:if="{{method === 'equal_principal'}}">
        <view class="info-row">
          <text>首月月供</text>
          <text class="text-bold">{{result.firstMonthPaymentStr}}元</text>
        </view>
        <view class="info-row">
          <text>末月月供</text>
          <text class="text-bold">{{result.lastMonthPaymentStr}}元</text>
        </view>
        <view class="info-row">
          <text>每月递减</text>
          <text class="text-bold">{{result.monthlyDecreaseStr}}元</text>
        </view>
      </view>

      <!-- 还款构成 -->
      <view class="chart-section">
        <view class="chart-title">还款构成</view>
        <view class="pie-chart">
          <view class="pie-visual">
            <view class="pie-principal" style="width: {{principalPercent}}%; background: #1890ff;"></view>
            <view class="pie-interest" style="width: {{interestPercent}}%; background: #f5222d;"></view>
          </view>
          <view class="pie-legend">
            <view class="legend-item">
              <view class="legend-dot" style="background:#1890ff"></view>
              <text>本金 {{principalPercent}}%</text>
            </view>
            <view class="legend-item">
              <view class="legend-dot" style="background:#f5222d"></view>
              <text>利息 {{interestPercent}}%</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 月收入评估 -->
      <view class="affordability" wx:if="{{monthlyIncome}}">
        <view class="section-title" style="margin-bottom:16rpx">💰 还款能力评估</view>
        <view class="income-input">
          <text>家庭月收入（元）：</text>
          <input class="income-field" type="digit" value="{{monthlyIncome}}" bindinput="onInput" data-field="monthlyIncome" />
        </view>
        <view class="afford-result afford-{{affordability.level}}">
          <text class="afford-ratio">月供占比 {{affordability.ratio}}%</text>
          <text class="afford-advice">{{affordability.advice}}</text>
        </view>
      </view>

      <!-- 查看还款明细 -->
      <view class="schedule-toggle" bindtap="toggleSchedule">
        <text>{{showSchedule ? '收起' : '查看'}}还款明细</text>
        <text class="toggle-arrow">{{showSchedule ? '▲' : '▼'}}</text>
      </view>

      <view class="schedule-list" wx:if="{{showSchedule && result.schedule}}">
        <view class="schedule-header">
          <text class="sh-col">期数</text>
          <text class="sh-col">月供(元)</text>
          <text class="sh-col">本金(元)</text>
          <text class="sh-col">利息(元)</text>
          <text class="sh-col">余额(元)</text>
        </view>
        <view class="schedule-row" wx:for="{{result.schedule}}" wx:key="month">
          <text class="sr-col">{{item.month}}</text>
          <text class="sr-col">{{item.payment}}</text>
          <text class="sr-col">{{item.principal}}</text>
          <text class="sr-col">{{item.interest}}</text>
          <text class="sr-col">{{item.remaining}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
