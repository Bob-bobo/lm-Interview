/* pages/surrounding/surrounding/surrounding.wxss - 周边配套评估样式 */

/* ========== 房源选择 ========== */
.house-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #f0f5ff, #e6f7ff);
  border-radius: 16rpx;
  border: 2rpx solid #bae7ff;
}
.house-picker-text { font-size: 28rpx; color: var(--text-primary); font-weight: 500; }
.house-picker-text.placeholder { color: var(--text-light); }
.picker-arrow { font-size: 24rpx; color: var(--text-light); }
.house-hint { font-size: 22rpx; color: var(--text-light); margin-top: 12rpx; }

/* ========== 雷达图 ========== */
.radar-section { padding-bottom: 0; }
.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.radar-wrap {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}
.radar-canvas {
  width: 500rpx;
  height: 500rpx;
}

/* ========== 综合评分 ========== */
.score-overview-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f5ff 50%, #f9f0ff 100%);
  border-radius: 20rpx;
}
.score-overview-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 8rpx;
}
.score-overview-row { display: flex; align-items: baseline; }
.score-overview-num { font-size: 64rpx; font-weight: 800; color: var(--primary-color); }
.score-overview-max { font-size: 24rpx; color: var(--text-light); margin-left: 4rpx; }
.score-overview-right { display: flex; flex-direction: column; align-items: flex-end; gap: 16rpx; }
.score-level-badge {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}
.score-actions { display: flex; gap: 12rpx; }
.action-btn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(24, 144, 255, 0.1);
  color: var(--primary-color);
}
.action-btn.reset {
  background: rgba(245, 34, 45, 0.08);
  color: #f5222d;
}

/* ========== 五维评分 ========== */
.score-list { display: flex; flex-direction: column; gap: 28rpx; }
.score-item { padding-bottom: 8rpx; }
.score-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}
.score-item-left { display: flex; align-items: center; gap: 12rpx; }
.score-icon { font-size: 32rpx; }
.score-name { font-size: 28rpx; color: var(--text-primary); font-weight: 600; }
.score-item-right { display: flex; align-items: baseline; }
.score-value { font-size: 40rpx; font-weight: 800; }
.score-max { font-size: 22rpx; color: var(--text-light); margin-left: 2rpx; }
.score-desc-text { font-size: 22rpx; color: var(--text-light); margin-bottom: 12rpx; display: block; }

.score-bar-wrap { position: relative; }
.score-bar-bg {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 4rpx;
}
.score-bar-fill { height: 100%; border-radius: 6rpx; transition: width 0.3s ease; }
.score-slider {
  margin: 0 !important;
  width: 100% !important;
  position: relative;
  top: -8rpx;
}

/* ========== 设施清单 ========== */
.facility-stat {
  font-size: 24rpx;
  color: var(--primary-color);
  background: rgba(24, 144, 255, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}
.facility-group { margin-bottom: 24rpx; }
.facility-group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  margin-bottom: 8rpx;
}
.facility-group-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.facility-group-count { font-size: 22rpx; color: var(--text-light); }
.facility-list { padding-left: 8rpx; }
.facility-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.facility-item:last-child { border-bottom: none; }
.facility-item-check { display: flex; align-items: center; gap: 16rpx; }
.facility-checkbox {
  width: 38rpx;
  height: 38rpx;
  border-radius: 10rpx;
  border: 2rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  flex-shrink: 0;
  transition: all 0.2s;
}
.facility-checkbox.checked {
  background: var(--success-color);
  border-color: var(--success-color);
  transform: scale(1.05);
}
.facility-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: color 0.2s;
}
.facility-text.checked { color: var(--text-primary); font-weight: 500; }
.facility-distance-input {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
  padding-left: 54rpx;
}
.distance-input {
  width: 160rpx;
  height: 52rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  color: var(--text-primary);
}
.distance-unit { font-size: 22rpx; color: var(--text-light); }

/* ========== 备注 ========== */
.notes-textarea {
  width: 100%;
  min-height: 180rpx;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
  box-sizing: border-box;
}
.notes-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}
.notes-count { font-size: 22rpx; color: var(--text-light); }
.save-btn {
  font-size: 26rpx;
  color: var(--primary-color);
  padding: 8rpx 28rpx;
  background: rgba(24, 144, 255, 0.1);
  border-radius: 8rpx;
  font-weight: 500;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: var(--text-primary); font-weight: 500; }
.empty-hint { font-size: 24rpx; color: var(--text-light); margin-top: 8rpx; }
.empty-btn {
  margin-top: 32rpx;
  font-size: 26rpx;
  color: #fff;
  background: var(--primary-color);
  padding: 14rpx 40rpx;
  border-radius: 24rpx;
}
