/* pages/house/list/list.wxss */

.search-bar {
  padding: 16rpx 24rpx;
  background: var(--bg-white);
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: var(--bg-gray);
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 56rpx;
}

.search-clear {
  font-size: 36rpx;
  color: var(--text-light);
  padding: 0 8rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: var(--bg-white);
  padding: 16rpx 24rpx;
  border-top: 1rpx solid var(--border-color);
  gap: 16rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 12rpx 0;
  border-radius: 8rpx;
  position: relative;
}

.filter-item.active {
  color: var(--primary-color);
  font-weight: 600;
}

.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: var(--primary-color);
}

.filter-count {
  font-size: 22rpx;
  color: var(--text-light);
  margin-left: 4rpx;
}

/* 房源卡片 */
.house-list {
  padding: 16rpx 24rpx;
}

.house-card {
  display: flex;
  background: var(--bg-white);
  border-radius: var(--radius-md);
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow);
  position: relative;
}

.house-card:active {
  background: var(--bg-light-gray);
}

.card-image {
  width: 200rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  flex-shrink: 0;
}

.card-img {
  width: 100%;
  height: 100%;
}

.card-image-placeholder {
  background: linear-gradient(135deg, #e6f7ff, #bae7ff);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 64rpx;
  opacity: 0.4;
}

.card-image-count {
  position: absolute;
  bottom: 8rpx;
  left: 8rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
}

.card-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 12rpx;
}

.card-price {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
}

.price-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--error-color);
}

.price-unit {
  font-size: 22rpx;
  color: var(--error-color);
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 8rpx 0;
}

.card-meta {
  font-size: 22rpx;
  color: var(--text-light);
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-source {
  font-size: 20rpx;
  color: var(--primary-color);
  background: var(--primary-light);
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.card-time {
  font-size: 20rpx;
  color: var(--text-light);
}

/* 对比复选框 */
.card-checkbox {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  z-index: 5;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border-color);
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.checkbox.checked {
  background: var(--primary-color);
  border-color: var(--primary-color);
}

/* 对比浮层 */
.compare-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: var(--bg-white);
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.compare-info {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.compare-btn {
  background: var(--primary-color);
  color: #fff;
  border: none;
  border-radius: 32rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.2;
}

.compare-btn::after {
  border: none;
}
