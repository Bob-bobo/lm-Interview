/* pages/ai/chat/chat.wxss */

.page-wrapper {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-gray);
}

.chat-messages {
  flex: 1;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.message {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
  animation: fadeIn 0.3s ease;
}

.message.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  background: var(--bg-white);
}

.message-bubble {
  max-width: 70%;
  padding: 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
}

.message.bot .message-bubble {
  background: var(--bg-white);
  color: var(--text-primary);
  border-top-left-radius: 8rpx;
  box-shadow: var(--shadow);
}

.message.user .message-bubble {
  background: var(--primary-color);
  color: #ffffff;
  border-top-right-radius: 8rpx;
}

.quick-questions {
  position: fixed;
  bottom: 120rpx;
  left: 0;
  right: 0;
  padding: 0 24rpx 16rpx;
  background: var(--bg-gray);
}

.quick-scroll {
  white-space: nowrap;
}

.quick-chip {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: var(--bg-white);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--primary-color);
  margin-right: 16rpx;
  box-shadow: var(--shadow);
}

.quick-chip:active {
  opacity: 0.7;
}

.chat-input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: var(--bg-white);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.chat-text-input {
  flex: 1;
  height: 72rpx;
  background: var(--bg-gray);
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.chat-send-btn {
  background: var(--primary-color);
  color: #ffffff;
  border: none;
  border-radius: 36rpx;
  padding: 0 36rpx;
  font-size: 28rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.chat-send-btn[disabled] {
  background: var(--border-color);
  color: var(--text-light);
}

.chat-send-btn::after {
  border: none;
}
