/* pages/ai/analyze/analyze.wxss */

.analyze-entry {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #f9f0ff 0%, #efdbff 100%);
  border: 2rpx solid #d3adf7;
}

.ai-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #722ed1, #531dab);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.ai-welcome {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ai-welcome .ai-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #531dab;
}

.ai-welcome .ai-desc {
  font-size: 24rpx;
  color: #722ed1;
  line-height: 1.5;
}

/* 快捷需求 */
.quick-needs {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.need-chip {
  padding: 16rpx 24rpx;
  background: var(--bg-gray);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.need-chip:active {
  background: var(--primary-light);
  border-color: var(--primary-color);
  color: var(--primary-color);
}

/* 输入区 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-white);
  padding: 16rpx 24rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.input-wrapper {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.chat-input {
  width: 100%;
  min-height: 80rpx;
  max-height: 200rpx;
  background: var(--bg-gray);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  line-height: 1.5;
}

.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.char-limit {
  font-size: 22rpx;
  color: var(--text-light);
}

.send-btn {
  background: var(--border-color);
  color: var(--text-light);
  border: none;
  border-radius: 32rpx;
  padding: 12rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.2;
}

.send-btn.active {
  background: var(--primary-color);
  color: #ffffff;
}

.send-btn[disabled] {
  background: var(--border-color);
  color: var(--text-light);
}

.send-btn::after {
  border: none;
}

/* 分析结果 */
.result-section {
  margin-bottom: 24rpx;
}

.analysis-summary {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.summary-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.summary-label {
  font-size: 26rpx;
  color: var(--text-light);
  min-width: 140rpx;
  flex-shrink: 0;
}

.summary-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  flex: 1;
}

.priority-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* 建议 */
.suggestions {
  margin-top: 8rpx;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.suggestion-item {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.suggestion-dot {
  color: var(--primary-color);
  font-size: 28rpx;
  flex-shrink: 0;
}

.suggestion-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 推荐房源 */
.recommend-card {
  background: var(--bg-white);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.recommend-card:active {
  background: var(--bg-light-gray);
}

.recommend-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.recommend-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--primary-color);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.recommend-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.recommend-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-brief {
  font-size: 24rpx;
  color: var(--text-light);
}

.recommend-score {
  font-size: 40rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.recommend-price {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.recommend-price .price {
  font-size: 36rpx;
  font-weight: 700;
}

.recommend-unit-price {
  font-size: 24rpx;
  color: var(--text-light);
}

.recommend-reasons {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.reason-tag {
  font-size: 22rpx;
  color: var(--success-color);
  background: #f6ffed;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}
