/* pages/index/index.wxss - 首页样式 */

/* 顶部区域 */
.header {
  position: relative;
  height: 280rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 50%, #0050b3 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 40rpx 32rpx 0;
}

.greeting {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.greeting-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.house-count {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 16rpx 32rpx;
  backdrop-filter: blur(10px);
}

.count-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

.count-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

/* 工具网格 */
.quick-tools {
  margin-top: -20rpx;
  position: relative;
  z-index: 2;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.tool-item:active {
  opacity: 0.7;
}

.tool-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.tool-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* AI推荐卡片 */
.ai-recommend {
  background: linear-gradient(135deg, #f9f0ff 0%, #efdbff 100%);
  border: 2rpx solid #d3adf7;
  border-radius: var(--radius-lg);
  padding: 28rpx;
}

.ai-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.ai-title {
  display: flex;
  align-items: center;
}

.ai-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.ai-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #531dab;
}

.ai-arrow {
  font-size: 24rpx;
  color: #722ed1;
}

.ai-desc {
  font-size: 26rpx;
  color: #722ed1;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.ai-tags {
  display: flex;
  flex-wrap: wrap;
}

/* 房源卡片 */
.house-card {
  background: var(--bg-white);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.house-card:active {
  background-color: var(--bg-light-gray);
}

.house-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.house-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.house-price {
  font-size: 36rpx;
  font-weight: 700;
}

.house-info {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.house-info text {
  background-color: var(--bg-gray);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.house-meta {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 购房贴士 */
.tip-card {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.tip-card:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.tip-content {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.view-all {
  font-size: 24rpx;
  color: var(--primary-color);
}
