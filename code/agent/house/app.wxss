/* app.wxss - 全局样式 */

/* ========== CSS变量 ========== */
page {
  --primary-color: #1890ff;
  --primary-light: #e6f7ff;
  --primary-dark: #096dd9;
  --success-color: #52c41a;
  --warning-color: #faad14;
  --error-color: #f5222d;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --bg-white: #ffffff;
  --bg-gray: #f5f5f5;
  --bg-light-gray: #fafafa;
  --border-color: #e8e8e8;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  --shadow-strong: 0 4rpx 24rpx rgba(0, 0, 0, 0.12);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;

  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-gray);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* ========== 通用布局 ========== */
.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.page-wrapper {
  min-height: 100vh;
  background-color: var(--bg-gray);
}

.section {
  background-color: var(--bg-white);
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title .icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

/* ========== 卡片 ========== */
.card {
  background-color: var(--bg-white);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.card:active {
  opacity: 0.9;
  transform: scale(0.98);
  transition: all 0.15s ease;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.card-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ========== 按钮 ========== */
.btn-primary {
  background-color: var(--primary-color);
  color: #ffffff;
  border: none;
  border-radius: var(--radius-lg);
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  line-height: 1;
  box-shadow: 0 4rpx 16rpx rgba(24, 144, 255, 0.3);
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  background-color: var(--primary-dark);
}

.btn-secondary {
  background-color: var(--primary-light);
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: var(--radius-lg);
  padding: 22rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

/* ========== 标签 ========== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-primary {
  background-color: var(--primary-light);
  color: var(--primary-color);
}

.tag-success {
  background-color: #f6ffed;
  color: var(--success-color);
}

.tag-warning {
  background-color: #fffbe6;
  color: var(--warning-color);
}

.tag-error {
  background-color: #fff1f0;
  color: var(--error-color);
}

/* ========== 价格显示 ========== */
.price {
  color: var(--error-color);
  font-weight: 600;
}

.price-large {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--error-color);
}

.price-unit {
  font-size: 24rpx;
  color: var(--error-color);
  font-weight: 400;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-state .text {
  font-size: 28rpx;
  color: var(--text-light);
  text-align: center;
  line-height: 1.6;
}

/* ========== 加载状态 ========== */
.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

/* ========== Flex 工具类 ========== */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* ========== 间距 ========== */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.ml-8 { margin-left: 8rpx; }
.mr-8 { margin-right: 8rpx; }
.p-16 { padding: 16rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

/* ========== 分割线 ========== */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 24rpx 0;
}

/* ========== 文本工具 ========== */
.text-primary { color: var(--primary-color); }
.text-success { color: var(--success-color); }
.text-warning { color: var(--warning-color); }
.text-error { color: var(--error-color); }
.text-light { color: var(--text-light); }
.text-center { text-align: center; }
.text-bold { font-weight: 600; }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 22rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }

/* ========== 输入框 ========== */
.input-field {
  background-color: var(--bg-gray);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.input-field-focus {
  border-color: var(--primary-color);
  background-color: var(--bg-white);
}

/* ========== 安全区域底部 ========== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 动画 ========== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.animate-fade-in {
  animation: fadeIn 0.3s ease;
}

.animate-slide-up {
  animation: slideUp 0.3s ease;
}

/* ========== 浮动按钮 ========== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--primary-color);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(24, 144, 255, 0.4);
  z-index: 100;
}

.fab:active {
  opacity: 0.8;
  transform: scale(0.95);
}
