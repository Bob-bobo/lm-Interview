/* pages/diary/detail/detail.wxss */
.diary-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.diary-house { font-size: 34rpx; font-weight: 700; color: var(--text-primary); }
.diary-date { font-size: 24rpx; color: var(--text-light); }
.diary-rating { margin-bottom: 16rpx; }
.stars { font-size: 36rpx; color: #faad14; letter-spacing: 4rpx; }
.diary-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 8rpx; }
.diary-content { font-size: 28rpx; color: var(--text-secondary); line-height: 1.8; white-space: pre-wrap; }
.image-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; }
.grid-image { width: 100%; height: 200rpx; border-radius: var(--radius-sm); }
